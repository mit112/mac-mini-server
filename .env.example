# Immich Environment Configuration
# Copy to .env and fill in your values

# Photo library location (external SSD)
UPLOAD_LOCATION=/Volumes/mit/immich/immich-uploads

# Postgres data location (external SSD)
DB_DATA_LOCATION=/Volumes/mit/immich/postgres

# Timezone
TZ=America/Chicago

# Immich version (pin to specific version or use "release" for latest)
IMMICH_VERSION=release

# Postgres credentials — generate a random password
DB_PASSWORD=CHANGE_ME_RANDOM_PASSWORD
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
