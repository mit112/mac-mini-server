<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mitsheth.watchdog</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/mitsheth/immich-app/backup-scripts/watchdog.sh</string>
    </array>

    <!-- Run every 12 hours (Hammerspoon handles real-time monitoring) -->
    <key>StartInterval</key>
    <integer>43200</integer>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
